    {
      "type": "SweetgreenFaqSection",
      "props": {
        "id": "SweetgreenFaqSection-fea94aae-3879-462e-a65b-848c9b111c08",
        "heading": {
          "text": {
            "field": "",
            "constantValue": {
              "en": "Frequently asked questions",
